{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakinu.github.io/MUGnet-News/schema/news-article.schema.json",
  "title": "MUGnet News article",
  "description": "A serialized public news article in a MUGnet News JSON feed.",
  "type": "object",
  "required": [
    "id",
    "date",
    "title",
    "summary",
    "body",
    "category",
    "linkUrl",
    "linkText",
    "external",
    "featured",
    "sites",
    "works"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "body": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "linkUrl": {
      "type": "string"
    },
    "linkText": {
      "type": "string"
    },
    "external": {
      "type": "boolean"
    },
    "featured": {
      "type": "boolean"
    },
    "sites": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "works": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "thumbnail": {
      "type": "string",
      "format": "uri"
    },
    "createdAt": {
      "type": "string",
      "format": "date"
    },
    "updatedAt": {
      "type": "string",
      "format": "date"
    }
  },
  "additionalProperties": true
}
