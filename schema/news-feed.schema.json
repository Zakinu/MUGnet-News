{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakinu.github.io/MUGnet-News/schema/news-feed.schema.json",
  "title": "MUGnet News feed",
  "description": "A site-scoped or work-scoped MUGnet News JSON feed.",
  "type": "object",
  "required": [
    "schemaVersion",
    "articles"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "site": {
      "type": "string",
      "minLength": 1
    },
    "work": {
      "$ref": "#/$defs/work"
    },
    "articles": {
      "type": "array",
      "items": {
        "$ref": "news-article.schema.json"
      }
    }
  },
  "oneOf": [
    {
      "required": ["site"],
      "properties": {
        "site": {}
      }
    },
    {
      "required": ["work"],
      "properties": {
        "work": {}
      }
    }
  ],
  "$defs": {
    "work": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
