{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakinu.github.io/MUGnet-News/schema/press-feed.schema.json",
  "title": "MUGnet Press & Interview feed",
  "description": "The complete or work-scoped MUGnet Press & Interview JSON feed.",
  "type": "object",
  "required": [
    "schemaVersion",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "collection": {
      "const": "press-and-interview"
    },
    "work": {
      "$ref": "#/$defs/work"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "press-entry.schema.json"
      }
    }
  },
  "oneOf": [
    {
      "required": ["collection"],
      "properties": {
        "collection": {}
      }
    },
    {
      "required": ["work"],
      "properties": {
        "work": {}
      }
    }
  ],
  "$defs": {
    "work": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
