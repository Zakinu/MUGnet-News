{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zakinu.github.io/MUGnet-News/schema/press-entry.schema.json",
  "title": "MUGnet Press & Interview entry",
  "description": "A serialized public Press & Interview entry in a MUGnet News JSON feed.",
  "type": "object",
  "required": [
    "id",
    "type",
    "date",
    "title",
    "publication",
    "summary",
    "body",
    "linkUrl",
    "works",
    "includeInNews"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "type": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "examples": ["press-release", "interview", "media-coverage"]
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "publication": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "body": {
      "type": "string"
    },
    "linkUrl": {
      "type": "string",
      "format": "uri"
    },
    "works": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "includeInNews": {
      "type": "boolean"
    },
    "createdAt": {
      "type": "string",
      "format": "date",
      "description": "Date when the archive record was created."
    },
    "updatedAt": {
      "type": "string",
      "format": "date",
      "deprecated": true,
      "description": "Legacy general update date retained for backward compatibility."
    },
    "contentUpdatedAt": {
      "type": "string",
      "format": "date",
      "description": "Date when reader-visible content or material facts were last changed."
    },
    "metadataUpdatedAt": {
      "type": "string",
      "format": "date",
      "description": "Date when internal metadata, taxonomy, or asset references were last changed."
    }
  },
  "additionalProperties": true
}
